  },
  {
    "id": 3,
    "key": "CH_ML_AND_CM#00003",
    "text": "Shift starting! I am ready. I have been ready for eleven minutes.",
    "type": "declaration",
    "intent": "smalltalk",
    "conditions": {
      "stress_min": 2,
      "stress_max": 6,
      "target": [
        "open_air"
      ],
