    "reply_to_intents": [],
    "weight": 1.0
  },
  {
    "id": 4,
    "key": "CH_ML_AND_CM#00004",
    "text": "Shift concluded and I did not break anything! That made me happy.",
    "type": "declaration",
    "intent": "smalltalk",
    "conditions": {
      "stress_min": 2,
      "stress_max": 6,
      "target": [
        "open_air"
      ],
      "recent_events": [
        "shift_end"
      ]
    },
    "reply_to_intents": [],
    "weight": 1.0
  },
  {
    "id": 5,
    "key": "CH_ML_AND_CM#00005",
    "text": "[NERVOUS] The reactor readings are concerning and I am experiencing something I believe is worry!",
    "type": "declaration",
    "intent": "fear_vent",
    "conditions": {
      "stress_min": 6,
      "stress_max": 11,
      "target": [
        "open_air"
      ],
      "recent_events": [
