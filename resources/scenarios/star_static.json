          "type": "set_flag",
          "flag": "star_static_active"
        },
        {
          "type": "crew_status_flag",
          "target": "affected",
          "flag": "shaken",
          "value": true
        },
        {
          "type": "radio_line",
          "speaker": "cast:affected",
          "text": "Did you see that? Right there. You had to have seen that."
        }
      ]
    },
    {
      "event_id": "ss_worse",
      "title": "It Gets Vivid",
      "description": "Deeper into the radiation band the visions sharpen \u2014 faces, voices, whole moments that feel remembered. The AI knows the mechanism, and knowing it doesn't make the crew's terror any less real.",
