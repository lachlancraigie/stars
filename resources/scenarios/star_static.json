    {
      "event_id": "ss_shimmer",
      "title": "Something at the Edge",
      "description": "Passing close to the star, crew start catching movement at the edge of vision \u2014 figures, shapes, a sense of being watched. The AI's instruments read a spike in hard radiation and nothing else in the room at all.",
      "tone_min": 0.2,
      "tone_max": 0.45,
      "weight": 10.0,
      "min_elapsed": 15.0,
      "cooldown": 9999.0,
      "one_shot": true,
      "conditions": [],
