      "event_id": "ru_seed",
      "title": "One Frightened Story",
      "description": "A crew member came back from the last leg shaken and told someone what they thought they saw. The AI logged the debrief; it was vague then. It is not staying vague.",
      "tone_min": 0.15,
      "tone_max": 0.4,
      "weight": 10.0,
      "min_elapsed": 20.0,
      "cooldown": 9999.0,
      "one_shot": true,
      "conditions": [],
      "outcomes": [
        {
          "type": "set_flag",
          "flag": "the_rumor_active"
        },
        {
          "type": "crew_status_flag",
          "target": "shaken_one",
          "flag": "shaken",
          "value": true
        },
        {
          "type": "radio_line",
          "speaker": "cast:shaken_one",
          "text": "I know what I saw. I don't care if the scanners say otherwise."
        }
      ]
    },
    {
