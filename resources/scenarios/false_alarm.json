          "flag": "false_alarm_active"
        },
        {
          "type": "radio_line",
          "speaker": "cast:lead",
          "text": "We've got a contact. Or we've got a broken sensor. Which is it?"
        }
      ]
    },
    {
      "event_id": "fa_flicker",
      "title": "It Flickers",
      "description": "The contact appears and vanishes on a rhythm that reads more like a fault than a ship. But faults and stealthed hulls can look alike on a bad day, and the AI won't stake the crew's nerves on probably.",
