  "events": [
    {
      "event_id": "si_noise",
      "title": "A Pattern in the Static",
      "description": "In the background hiss of deep space, the AI's filters flag a structure that shouldn't be there \u2014 regular, layered, not quite random. Dismissed as instrument noise, it comes back on the next sweep, a little clearer.",
      "tone_min": 0.15,
      "tone_max": 0.4,
      "weight": 10.0,
      "min_elapsed": 15.0,
      "cooldown": 9999.0,
      "one_shot": true,
      "conditions": [],
      "outcomes": [
        {
          "type": "set_flag",
          "flag": "the_signal_active"
        },
        {
          "type": "radio_line",
          "speaker": "cast:lead",
          "text": "There's a shape in the noise. I keep telling myself it's nothing."
        }
      ]
    },
    {
      "event_id": "si_recur",
      "title": "It Recurs",
      "description": "The signal returns, and returns, each time carrying a touch more structure. It isn't a message being decoded so much as something, somewhere, learning how to be heard.",
      "tone_min": 0.2,
      "tone_max": 0.45,
      "weight": 5.0,
      "min_elapsed": 80.0,
      "cooldown": 100.0,
      "one_shot": false,
      "conditions": [
        {
          "type": "flag_set",
          "flag": "the_signal_active"
        },
        {
          "type": "flag_unset",
          "flag": "signal_understood"
        }
      ],
      "outcomes": []
    },
    {
      "event_id": "si_dread",
      "title": "Wonder or Threat",
      "description": "The crew split on what it means. Some hear a first contact worth the whole voyage; others hear a predator's lure. The AI, with the patience and memory neither has, gets to shape which story wins.",
      "tone_min": 0.2,
      "tone_max": 0.5,
      "weight": 4.0,
      "min_elapsed": 120.0,
      "cooldown": 300.0,
      "one_shot": true,
      "conditions": [
        {
          "type": "flag_set",
          "flag": "the_signal_active"
        }
      ],
      "outcomes": [
        {
          "type": "set_flag",
          "flag": "crew_divided"
        }
      ]
    },
    {
      "event_id": "si_obsess",
      "title": "Someone Can't Let Go",
      "description": "One crew member stops sleeping, filling notebooks with the signal's shape, hearing it in the ship's hum. The transmission is harmless; the human need to make it mean something is not always so.",
      "tone_min": 0.25,
      "tone_max": 0.55,
      "weight": 2.0,
      "min_elapsed": 170.0,
      "cooldown": 300.0,
      "one_shot": true,
      "conditions": [
        {
          "type": "flag_set",
          "flag": "crew_divided"
        },
        {
          "type": "flag_unset",
          "flag": "signal_understood"
        }
      ],
      "outcomes": [
        {
          "type": "set_flag",
          "flag": "crew_obsessed"
        }
      ]
    },
    {
      "event_id": "si_reply",
      "title": "Do We Answer",
      "description": "The AI can compose a reply \u2014 a wave back into the dark \u2014 or keep the ship silent and listening. Neither is dangerous. Both are the kind of choice that defines what sort of ship this is.",
      "tone_min": 0.15,
      "tone_max": 0.45,
      "weight": 3.0,
      "min_elapsed": 100.0,
      "cooldown": 300.0,
      "one_shot": true,
      "conditions": [
        {
          "type": "flag_set",
          "flag": "the_signal_active"
        }
      ],
      "outcomes": [
        {
          "type": "set_flag",
          "flag": "reply_considered"
        }
      ]
    },
    {
      "event_id": "si_calm",
      "title": "It Means Us No Harm",
      "description": "The more the AI listens, the gentler the signal reads \u2014 no menace in it, only patience. Sometimes the merciful truth of deep space is that the thing in the dark just wanted to say hello.",
      "tone_min": 0.1,
      "tone_max": 0.4,
