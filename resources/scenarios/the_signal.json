          {
            "type": "radio_line",
            "speaker": "cast:lead",
            "text": "Decoded the pattern. It's a beacon saying hello to the dark. That's all."
          }
        ]
      },
      {
        "id": "solve_2_sophontology",
        "interval": 38.0,
        "crew": "best_skill:Sophontology",
        "stat": "intellect",
        "skill": "Sophontology",
        "requires_flags": [
          "the_signal_active"
        ],
        "successes_needed": 2,
        "on_success": [
          {
            "type": "radio_line",
            "speaker": "cast:lead",
            "text": "Whatever's sending this thinks slowly and means no harm. I'd stake the ship on it."
          }
        ],
        "on_fail": [
          {
            "type": "crew_stress",
            "target": "best_skill:Sophontology",
            "amount": 1
          }
        ],
        "on_solved": [
          {
            "type": "set_flag",
            "flag": "signal_understood"
          },
          {
            "type": "radio_line",
            "speaker": "cast:lead",
            "text": "It's cognition, not a threat. Something learning to be heard. Beautiful, actually."
          }
        ]
      }
