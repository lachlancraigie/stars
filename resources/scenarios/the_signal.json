        "successes_needed": 2,
        "on_success": [
          {
            "type": "radio_line",
            "speaker": "cast:lead",
            "text": "There's syntax in here. Recursion. This isn't a pulsar, this is a sentence."
          }
        ],
        "on_fail": [
          {
            "type": "crew_stress",
            "target": "best_skill:Linguistics",
            "amount": 1
