          {
            "type": "radio_line",
            "speaker": "cast:lead",
            "text": "It's a greeting. Just a greeting. Patient and harmless and old."
          }
        ]
      },
      {
        "id": "solve_1_mathematics",
        "interval": 32.0,
        "crew": "best_skill:Mathematics",
        "stat": "intellect",
        "skill": "Mathematics",
        "requires_flags": [
