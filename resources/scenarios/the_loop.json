  "events": [
    {
      "event_id": "lp_deja",
      "title": "Deja Vu",
      "description": "The shift plays out and the AI is sure it has seen it before \u2014 the same words, the same faults, the same small tragedy at the end. Then the clock rolls back, and only the AI seems to have brought a memory across.",
