        {
          "type": "set_flag",
          "flag": "the_loop_active"
        },
        {
          "type": "radio_line",
          "speaker": "cast:lead",
          "text": "Have we done this before? No. Forget I asked. But have we?"
        }
      ]
    },
    {
      "event_id": "lp_death",
      "title": "It Kills the Same Way",
      "description": "The loop's fixed point is a death \u2014 the same crew member, the same coolant failure, the same too-late response. The AI watches it happen again, holding the awful knowledge that this iteration was always going to end here.",
