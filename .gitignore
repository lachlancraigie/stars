# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/

# System files
.DS_Store
Thumbs.db

# Asset generation pipeline (tools/asset_gen) -- staged/unreviewed generations
# are not committed; they go through promote.py after human QA review.
tools/asset_gen/staging/

# Godot editor cache
.godot/

# Secrets - never commit
.env
**/.env
*.env

# Generated audio (large; regenerate via tools/audio_gen)
assets/audio/dialogue/

# Python cache / tool logs
__pycache__/
tools/**/*.log
